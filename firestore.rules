rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdminUser() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /cars/{carId} {
      allow read: if true;
      allow create, update, delete: if isAdminUser();
    }

    match /packages/{packageId} {
      allow read: if true;
      allow create, update, delete: if isAdminUser();
    }

    match /bookings/{bookingId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if isAdminUser();
    }

    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if request.auth != null && request.auth.uid == adminId;
    }

    match /settings/{document} {
      allow read: if true;
      allow write: if isAdminUser();
    }

    match /settings/{document}/messages/{messageId} {
      allow create: if true;
      allow read, delete: if isAdminUser();
    }

    match /notifications/{notificationId} {
      allow read, write: if isAdminUser();
    }
  }
}
